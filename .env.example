# Copy this to ~/.shooter/.env (or run: shooter setup)
# Only API_KEY is required — everything else is optional.

# ──────────────────────────────────────
# Required — server starts with just this
# ──────────────────────────────────────

# Shared auth key — used by the server AND hooks (export API_KEY=... in your shell)
# Auto-generated by `shooter setup` — press Enter to accept the default.
API_KEY=your-api-key-here

# Server port (default: 54007)
# PORT=54007

# ──────────────────────────────────────
# Optional — iOS Push Notifications
# Add later with: shooter setup --push
# ──────────────────────────────────────

# Apple Push Notification Service credentials
# APNS_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----"
# APNS_KEY_ID=YOUR_KEY_ID            # 10-char key ID from Apple Developer portal
# APNS_TEAM_ID=YOUR_TEAM_ID          # 10-char team ID from Apple Developer portal
# APNS_BUNDLE_ID=your.bundle.id      # Must match Xcode project bundle identifier
# APNS_PRODUCTION=false              # Set true for TestFlight / App Store builds

# Target iOS device token (64-char hex from device registration)
# DEVICE_TOKEN=your-64-char-hex-device-token

# ──────────────────────────────────────
# Optional — Android Push Notifications
# Add later with: shooter setup --push
# ──────────────────────────────────────

# Firebase Cloud Messaging credentials
# FCM_PROJECT_ID=
# FCM_CLIENT_EMAIL=
# FCM_PRIVATE_KEY=

# Target Android device token
# ANDROID_DEVICE_TOKEN=

# Which platform to send to: "ios" or "android"
# DEVICE_PLATFORM=ios
