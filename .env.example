# Shooter Dashboard Environment Configuration
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to version control

# ===== SvelteKit Configuration =====
# Environment mode for SvelteKit
NODE_ENV=development
PUBLIC_APP_NAME=Shooter Dashboard
PUBLIC_APP_VERSION=1.0.0

# ===== Apple Push Notifications (APNs) Configuration =====
# Required: APNs authentication key (.p8 file content)
#
# FORMATS SUPPORTED (choose one):
#
# 1. PEM Format with Headers (RECOMMENDED):
#    APNS_KEY_P8="-----BEGIN PRIVATE KEY-----
#    MIGTAgEAMBMGByqGSM49AgEGCCqGSM49AwEHBHkwdwIBAQQgY/khMFkUNPQs...
#    XT7oSa2S8LihWj12VHXIzrWnsMBwgVBatRgKiiTQfHWBfrsqmPW7D68ACPOI...
#    -----END PRIVATE KEY-----"
#
# 2. Raw Key Without Headers (Auto-formatted):
#    APNS_KEY_P8=MIGTAgEAMBMGByqGSM49AgEGCCqGSM49AwEHBHkwdwIBAQQgY/khMFkUNPQs...
#
# To extract from .p8 file:
#   cat AuthKey_XXXXXXXXXX.p8
#
APNS_KEY_P8=your-apns-key-content-here

# Required: APNs Key ID (10-character string from Apple Developer Portal)
APNS_KEY_ID=your-key-id

# Required: APNs Team ID (10-character string from Apple Developer Portal)
APNS_TEAM_ID=your-team-id

# Required: iOS app bundle identifier
APNS_BUNDLE_ID=com.yourcompany.shooter

# Optional: APNs environment (development or production)
APNS_ENVIRONMENT=development

# ===== Authentication Configuration =====
# Required: Secret key for JWT token generation (minimum 32 characters)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters

# Required: Admin authentication credentials
AUTH_USERNAME=admin
AUTH_PASSWORD=your-secure-admin-password

# Optional: JWT token expiration (default: 30 days)
JWT_EXPIRES_IN=30d

# Optional: Session cookie name
SESSION_COOKIE_NAME=shooter-session

# ===== Storage Configuration =====
# Storage backend: memory, redis, or database
STORAGE_TYPE=memory

# Redis configuration (if using Redis storage)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Database configuration (if using database storage)
DATABASE_URL=postgresql://username:password@localhost:5432/shooter_db

# Storage retry configuration
STORAGE_RETRY_ATTEMPTS=3
STORAGE_RETRY_DELAY=1000

# ===== Security Configuration =====
# Required: Bearer token for Claude Code webhook authentication
# Generate with: openssl rand -hex 32
BEARER_TOKEN=your-webhook-bearer-token

# Optional: Webhook HMAC secret for signature validation
WEBHOOK_SECRET=your-webhook-hmac-secret

# Optional: CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Optional: Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=900000

# ===== Monitoring & Logging =====
# Optional: Log level (error, warn, info, debug)
LOG_LEVEL=info

# Optional: Enable performance monitoring
ENABLE_METRICS=true

# Optional: Metrics aggregation window (milliseconds)
METRICS_WINDOW=300000

# Optional: Enable health monitoring
ENABLE_HEALTH_CHECKS=true

# ===== Development Configuration =====
# Optional: Enable debug mode
DEBUG=false

# Optional: Enable verbose logging
VERBOSE=false

# Optional: Mock external services for testing
MOCK_APNS=false
MOCK_NOTIFICATIONS=false

# ===== Production Configuration =====
# Optional: Production domain for cookies
DOMAIN=yourdomain.com

# Optional: Enable secure cookies in production
SECURE_COOKIES=true

# Optional: Error tracking service
SENTRY_DSN=your-sentry-dsn-url

# Optional: Analytics tracking
ANALYTICS_ID=your-analytics-id

# ===== Vercel-specific Configuration =====
# Optional: Vercel region preference
VERCEL_REGION=iad1

# Optional: Function memory allocation
VERCEL_FUNCTION_MEMORY=1024

# ===== Claude Code Integration =====
# Optional: Enable Claude Code hooks
ENABLE_CLAUDE_HOOKS=true

# Optional: Claude Code notification categories
CLAUDE_CATEGORIES=debug,feature,testing,learning,error

# Optional: Notification filtering
ENABLE_NOTIFICATION_FILTERING=true
MIN_NOTIFICATION_INTERVAL=5000

# ===== Mobile-First Dashboard Configuration =====
# Optional: Mobile optimization settings
ENABLE_MOBILE_OPTIMIZATION=true
MOBILE_BREAKPOINT=768
TABLET_BREAKPOINT=1024

# Optional: Real-time updates
ENABLE_WEBSOCKETS=true
WEBSOCKET_HEARTBEAT=30000

# Optional: Offline mode
ENABLE_OFFLINE_MODE=true
CACHE_STRATEGY=stale-while-revalidate

# ===== Performance Tuning =====
# Optional: Bundle optimization
BUNDLE_ANALYZER=false
PRELOAD_STRATEGY=modulepreload

# Optional: Image optimization
ENABLE_IMAGE_OPTIMIZATION=true
IMAGE_QUALITY=80

# Optional: Service worker configuration
ENABLE_SERVICE_WORKER=true
SW_CACHE_STRATEGY=networkfirst

# ===== Legacy Support (for backward compatibility) =====
# Deprecated: Use BEARER_TOKEN instead
API_KEY=your_secret_api_key_here

# Deprecated: Use APNS_KEY_P8 instead
APNS_KEY="-----BEGIN PRIVATE KEY-----
your_p8_key_content_here
-----END PRIVATE KEY-----"

# Deprecated: Device tokens now managed via dashboard
DEVICE_TOKEN=your_device_token_from_ios_app