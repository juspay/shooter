# API Authentication
API_KEY=your_secret_api_key_here

# APNs Configuration
APNS_KEY_ID=your_apns_key_id_here
APNS_TEAM_ID=your_team_id_here
APNS_BUNDLE_ID=com.example.claudenotifier
APNS_KEY="-----BEGIN PRIVATE KEY-----
your_p8_key_content_here
-----END PRIVATE KEY-----"

# Device Token (from iOS app)
DEVICE_TOKEN=your_device_token_from_ios_app

# Environment
NODE_ENV=production