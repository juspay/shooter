{
  "name": "shooter-ios-notifier",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite dev --open",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "start": "node build",
    "deploy": "vercel --prod",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "pnpm run format:check && pnpm run lint && pnpm run check"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@sveltejs/adapter-auto": "^3.3.1",
    "@sveltejs/kit": "^2.50.1",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.1.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.4.0",
    "eslint-plugin-svelte": "^3.14.0",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.4.1",
    "svelte": "^5.22.0",
    "svelte-check": "^4.1.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.54.0",
    "vite": "^6.0.5"
  },
  "dependencies": {
    "@parse/node-apn": "^6.5.0",
    "@sveltejs/adapter-vercel": "^5.8.1",
    "apn": "^2.2.0",
    "dotenv": "^16.6.1",
    "jsonwebtoken": "^9.0.2"
  }
}
