{
  "name": "@juspay/shooter",
  "version": "1.0.0",
  "description": "Bidirectional communication server for Claude Code and iOS — push notifications, remote terminal, session viewing",
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "license": "MIT",
  "author": {
    "name": "Juspay Technologies",
    "email": "support@juspay.in",
    "url": "https://juspay.io"
  },
  "homepage": "https://github.com/juspay/shooter#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/juspay/shooter.git"
  },
  "bugs": {
    "url": "https://github.com/juspay/shooter/issues"
  },
  "bin": {
    "shooter": "bin/shooter.cjs"
  },
  "files": [
    "bin/",
    "build/",
    "scripts/",
    "server.ts",
    "src/",
    "svelte.config.js",
    "tsconfig.json",
    "vite.config.ts",
    ".claude/hooks/",
    ".claude/settings.json"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "node-pty"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "postinstall": "node-gyp rebuild --directory=node_modules/node-pty || true",
    "build": "vite build",
    "postbuild": "cp src/lib/modules/server/terminal/pty-holder.cjs build/pty-holder.cjs",
    "dev": "vite dev --open",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "start": "tsx server.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:fix:generated": "eslint './src/generated/**/*.{js,ts}' --fix",
    "format:generated": "prettier --write ./src/generated/*",
    "gen:types": "npx type-crafter generate typescript-with-decoders ./specs/types/index.yaml ./src/generated/types SingleFile SingleFile && pnpm run lint:fix:generated && pnpm run format:generated",
    "setup": "node scripts/setup.cjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@sveltejs/adapter-node": "^5.2.0",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dompurify": "^3.2.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.2.0",
    "@types/qrcode": "^1.5.6",
    "@types/ws": "^8.18.1",
    "@vite-pwa/sveltekit": "^1.1.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.4.0",
    "eslint-plugin-svelte": "^3.14.0",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.4.1",
    "svelte": "^5.49.1",
    "svelte-check": "^4.3.6",
    "type-crafter": "^0.10.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@juspay/svelte-ui-components": "^2.13.1",
    "@parse/node-apn": "^7.1.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^4.0.0",
    "dompurify": "^3.3.3",
    "dotenv": "^17.2.3",
    "firebase-admin": "^13.7.0",
    "jsonwebtoken": "^9.0.3",
    "marked": "^17.0.4",
    "node-pty": "1.1.0",
    "qrcode": "^1.5.4",
    "tsx": "^4.19.0",
    "type-decoder": "^2.2.0",
    "ws": "^8.18.0"
  }
}
