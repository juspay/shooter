{
  "name": "shooter-ios-notifier",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run vite build",
    "dev": "bun run vite dev --port 7777 --open",
    "preview": "bun run vite preview",
    "check": "bun run svelte-kit sync && bun run svelte-check --tsconfig ./tsconfig.json",
    "start": "bun run build",
    "deploy": "vercel --prod",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "compare-screenshots": "bun run scripts/compare-screenshots.ts"
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@sveltejs/adapter-auto": "^3.3.1",
    "@sveltejs/kit": "^2.14.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.2.8",
    "@testing-library/user-event": "^14.6.1",
    "@types/ioredis": "^4.28.10",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.1.0",
    "@types/pg": "^8.11.0",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "@vitest/coverage-v8": "^1.0.0",
    "@vitest/ui": "^1.0.0",
    "eslint": "^9.38.0",
    "eslint-plugin-svelte": "^3.12.5",
    "globals": "^16.5.0",
    "happy-dom": "^20.0.10",
    "jsdom": "^27.1.0",
    "playwright": "^1.56.1",
    "svelte": "^5.22.0",
    "svelte-check": "^4.1.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.0",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "@juspay/svelte-ui-components": "^1.34.1",
    "@parse/node-apn": "^6.5.0",
    "@sveltejs/adapter-vercel": "^5.8.1",
    "apn": "^2.2.0",
    "better-sqlite3": "^12.4.1",
    "dotenv": "^16.6.1",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.15.3",
    "pg": "^8.16.3",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0"
  }
}
