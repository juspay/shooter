{
  "name": "shooter-ios-notifier",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "vite build",
    "dev": "vite dev --open",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "start": "node build",
    "deploy": "vercel --prod",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:fix:generated": "eslint './src/generated/**/*.{js,ts}' --fix",
    "format:generated": "prettier --write ./src/generated/*",
    "gen:types": "npx type-crafter generate typescript-with-decoders ./specs/types/index.yaml ./src/generated/types SingleFile SingleFile && pnpm run lint:fix:generated && pnpm run format:generated"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/adapter-vercel": "^6.3.1",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.2.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.4.0",
    "eslint-plugin-svelte": "^3.14.0",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.4.1",
    "svelte": "^5.49.1",
    "svelte-check": "^4.3.6",
    "type-crafter": "^0.10.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@parse/node-apn": "^7.1.0",
    "dotenv": "^17.2.3",
    "jsonwebtoken": "^9.0.3",
    "node-pty": "1.1.0",
    "type-decoder": "^2.2.0"
  }
}
